+#[test]
+fn manual_empty_debug_info() {
+    use gimli::{DebugAbbrev, DebugInfo, LittleEndian};
+    let debug_abbrev = DebugAbbrev::new(&[], LittleEndian);
+    let debug_info = DebugInfo::new(&[0, 0, 0, 0, 4, 0, 0, 0, 0, 0, 0, 0], LittleEndian);
+    let mut units = debug_info.units();
+    assert!(units.next().is_ok());
+}
