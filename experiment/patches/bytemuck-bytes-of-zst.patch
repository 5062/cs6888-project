+
+#[test]
+fn manual_bytes_of_zst() {
+    let zst: [u32; 0] = [];
+    let result = bytes_of(&zst);
+    assert_eq!(result.len(), 0);
+}
+
+#[test]
+fn manual_bytes_of_nonempty_array() {
+    let arr: [u32; 3] = [1, 2, 3];
+    let result = bytes_of(&arr);
+    assert_eq!(result.len(), 12);
+}
+
+#[test]
+fn manual_bytes_of_scalar() {
+    let val: u32 = 42;
+    let result = bytes_of(&val);
+    assert_eq!(result.len(), 4);
+}
