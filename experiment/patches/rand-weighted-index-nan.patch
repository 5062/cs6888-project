+#[test]
+fn manual_weighted_index_nan() {
+    use crate::distributions::WeightedIndex;
+    let result = WeightedIndex::new(vec![std::f64::NAN, 1.0]);
+    assert!(result.is_err(), "NaN weight should be rejected");
+}
+
+#[test]
+fn manual_weighted_index_valid() {
+    use crate::distributions::WeightedIndex;
+    let result = WeightedIndex::new(vec![1.0, 2.0, 3.0]);
+    assert!(result.is_ok());
+}
+
+#[test]
+fn manual_weighted_index_zero_weight() {
+    use crate::distributions::WeightedIndex;
+    let result = WeightedIndex::new(vec![0.0, 1.0]);
+    assert!(result.is_ok());
+}
