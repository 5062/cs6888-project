@@ -755,3 +755,40 @@ fn byte_order_mark() {
     let string = "foo\u{feff}";
     string.parse::<TokenStream>().unwrap_err();
 }
+
+#[test]
+fn manual_source_text_multibyte() {
+    let s = std::str::from_utf8(b"    \xf0\x93\x80\x95 c    ").unwrap();
+    let mut tokens = s
+        .parse::<proc_macro2::TokenStream>()
+        .unwrap()
+        .into_iter();
+    let ident1 = tokens.next().unwrap();
+    let _ = ident1.span().source_text();
+    let ident2 = tokens.next().unwrap();
+    let _ = ident2.span().source_text();
+}
+
+#[test]
+fn manual_source_text_ascii() {
+    let input = "abc def";
+    let mut tokens = input
+        .parse::<proc_macro2::TokenStream>()
+        .unwrap()
+        .into_iter();
+    let ident = tokens.next().unwrap();
+    let text = ident.span().source_text().unwrap();
+    assert_eq!(text, "abc");
+}
+
+#[test]
+fn manual_source_text_single() {
+    let input = "xyz";
+    let mut tokens = input
+        .parse::<proc_macro2::TokenStream>()
+        .unwrap()
+        .into_iter();
+    let ident = tokens.next().unwrap();
+    let text = ident.span().source_text().unwrap();
+    assert_eq!(text, "xyz");
+}
