+
+#[test]
+fn manual_file_set_path_windows_drive() {
+    let mut url = url::Url::parse("file:///d:/test").unwrap();
+    url.set_path("d:\\test\\main.foo");
+}
+
+#[test]
+fn manual_file_set_path_no_drive() {
+    let mut url = url::Url::parse("file:///test").unwrap();
+    url.set_path("/other/file.txt");
+    assert_eq!(url.path(), "/other/file.txt");
+}
+
+#[test]
+fn manual_http_set_path() {
+    let mut url = url::Url::parse("http://example.com/old").unwrap();
+    url.set_path("/new/path");
+    assert_eq!(url.path(), "/new/path");
+}
