+#[test]
+fn manual_malformed_closing_tag() {
+    let mut tpl = TinyTemplate::new();
+    let result = tpl.add_template("template", "{#}");
+    // Should return an error, not panic
+    assert!(result.is_err());
+}
+
+#[test]
+fn manual_valid_template() {
+    let mut tpl = TinyTemplate::new();
+    let result = tpl.add_template("template", "hello {name}");
+    assert!(result.is_ok());
+}
+
+#[test]
+fn manual_empty_template() {
+    let mut tpl = TinyTemplate::new();
+    let result = tpl.add_template("template", "");
+    assert!(result.is_ok());
+}
