+#[test]
+fn manual_set_hostname_username() {
+    let mut url = url::Url::parse("arhttpsps:/.//eom/dae.com/\\\\t\\:").unwrap();
+    let _ = url::quirks::set_hostname(&mut url, "//eom/datcom/\\\\t\\://eom/data.cs");
+}
+
+#[test]
+fn manual_set_hostname_simple() {
+    let mut url = url::Url::parse("http://example.com/path").unwrap();
+    url.set_host(Some("newhost.com")).unwrap();
+    assert_eq!(url.host_str(), Some("newhost.com"));
+}
+
+#[test]
+fn manual_username_empty() {
+    let url = url::Url::parse("http://example.com/path").unwrap();
+    assert_eq!(url.username(), "");
+}
