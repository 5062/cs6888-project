+
+#[test]
+fn manual_key_from_str_despan_long_key_short_document() {
+    let mut doc = r#"a=1"#.parse::<Document>().unwrap();
+    let key = "bbbbbb".parse::<Key>().unwrap();
+    let table = doc.as_table_mut();
+    table.insert_formatted(
+        &key,
+        toml_edit::Item::Value(Value::Integer(toml_edit::Formatted::new(2))),
+    );
+
+    assert_eq!(doc.to_string(), "a=1\nbbbbbb = 2\n");
+}
